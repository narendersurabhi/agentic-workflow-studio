{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResumeGapReportGenerateOutput",
  "type": "object",
  "properties": {
    "report_text": {
      "type": "string",
      "minLength": 1
    },
    "section_recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "section": {"type": "string"},
          "issues": {
            "type": "array",
            "items": {"type": "string"}
          },
          "recommended_changes": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "required": [
          "section",
          "issues",
          "recommended_changes"
        ],
        "additionalProperties": false
      }
    },
    "priority_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "coverage_summary": {
      "type": "object",
      "properties": {
        "explicit_match_count": {"type": "integer"},
        "implicit_match_count": {"type": "integer"},
        "missing_requirement_count": {"type": "integer"}
      },
      "required": [
        "explicit_match_count",
        "implicit_match_count",
        "missing_requirement_count"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "report_text",
    "section_recommendations",
    "priority_actions",
    "coverage_summary"
  ],
  "additionalProperties": false
}
