{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResumeSkillInjectOutput",
  "type": "object",
  "properties": {
    "tailored_resume": {
      "type": "object"
    },
    "applied_skills": {
      "type": "array",
      "items": {"type": "string"}
    },
    "placement_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "skill": {"type": "string"},
          "sections": {
            "type": "array",
            "items": {"type": "string"}
          },
          "rationale": {"type": "string"}
        },
        "required": ["skill", "sections", "rationale"],
        "additionalProperties": false
      }
    }
  },
  "required": ["tailored_resume", "applied_skills", "placement_summary"],
  "additionalProperties": false
}
