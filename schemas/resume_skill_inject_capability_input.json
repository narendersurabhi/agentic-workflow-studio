{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResumeSkillInjectCapabilityInput",
  "type": "object",
  "properties": {
    "tailored_resume": {
      "type": "object"
    },
    "skills": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "target_sections": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["summary", "skills", "experience", "projects", "certifications"]
      }
    },
    "job_description": {
      "type": "string"
    },
    "instructions": {
      "type": "string"
    }
  },
  "required": ["tailored_resume", "skills"],
  "additionalProperties": false
}
